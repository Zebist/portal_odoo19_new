#. module: website_sale_custom
#: model:mail.template,body_html:website_sale_custom.mail_template_sale_order_website_inquiry
msgid ""
"<div>\n"
"    <p>A new quote request was submitted from the website.</p>\n"
"    <p>\n"
"        <strong>Order:</strong> <t t-out=\"object.name\"/>\n"
"        <br/>\n"
"        <strong>Customer email:</strong> <t t-out=\"object.inquiry_contact_email or object.partner_id.email or ''\"/>\n"
"        <br t-if=\"object.inquiry_company_name\"/>\n"
"        <t t-if=\"object.inquiry_company_name\">\n"
"            <strong>Company:</strong> <t t-out=\"object.inquiry_company_name\"/>\n"
"        </t>\n"
"    </p>\n"
"    <p>\n"
"        <a t-att-href=\"'%s/web#id=%s&amp;model=sale.order&amp;view_type=form' % (object.get_base_url(), object.id)\">Open quotation</a>\n"
"    </p>\n"
"    <table t-if=\"object.order_line\" border=\"0\" cellpadding=\"4\" cellspacing=\"0\" width=\"100%\">\n"
"        <thead>\n"
"            <tr>\n"
"                <th align=\"left\">Product</th>\n"
"                <th align=\"right\">Qty</th>\n"
"                <th align=\"right\">Expected unit price</th>\n"
"                <th align=\"left\">Note</th>\n"
"            </tr>\n"
"        </thead>\n"
"        <tbody>\n"
"            <t t-foreach=\"object.order_line\" t-as=\"line\">\n"
"                <tr t-if=\"line.product_id\">\n"
"                    <td><t t-out=\"line.product_id.display_name\"/></td>\n"
"                    <td align=\"right\"><t t-out=\"line.product_uom_qty\"/></td>\n"
"                    <td align=\"right\">\n"
"                        <t t-if=\"line.price_unit not in (False, None)\">\n"
"                            <span t-field=\"line.price_unit\" t-options=\"{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: line.currency_id}\"/>\n"
"                        </t>\n"
"                        <t t-else=\"\">—</t>\n"
"                    </td>\n"
"                    <td><t t-out=\"line.inquiry_line_note or ''\"/></td>\n"
"                </tr>\n"
"            </t>\n"
"        </tbody>\n"
"    </table>\n"
"    <t t-if=\"not is_html_empty(object.note)\">\n"
"        <p style=\"margin-top: 16px; margin-bottom: 8px;\">\n"
"            <strong>Order note:</strong>\n"
"        </p>\n"
"        <div style=\"font-size: 13px;\" t-out=\"object.note\"/>\n"
"    </t>\n"
"</div>\n"
"            "
msgstr ""
"<div>\n"
"    <p>网站提交了新的询价请求。</p>\n"
"    <p>\n"
"        <strong>订单：</strong> <t t-out=\"object.name\"/>\n"
"        <br/>\n"
"        <strong>客户邮箱：</strong> <t t-out=\"object.inquiry_contact_email or object.partner_id.email or ''\"/>\n"
"        <br t-if=\"object.inquiry_company_name\"/>\n"
"        <t t-if=\"object.inquiry_company_name\">\n"
"            <strong>公司：</strong> <t t-out=\"object.inquiry_company_name\"/>\n"
"        </t>\n"
"    </p>\n"
"    <p>\n"
"        <a t-att-href=\"'%s/web#id=%s&amp;model=sale.order&amp;view_type=form' % (object.get_base_url(), object.id)\">打开报价单</a>\n"
"    </p>\n"
"    <table t-if=\"object.order_line\" border=\"0\" cellpadding=\"4\" cellspacing=\"0\" width=\"100%\">\n"
"        <thead>\n"
"            <tr>\n"
"                <th align=\"left\">商品</th>\n"
"                <th align=\"right\">数量</th>\n"
"                <th align=\"right\">期望单价</th>\n"
"                <th align=\"left\">备注</th>\n"
"            </tr>\n"
"        </thead>\n"
"        <tbody>\n"
"            <t t-foreach=\"object.order_line\" t-as=\"line\">\n"
"                <tr t-if=\"line.product_id\">\n"
"                    <td><t t-out=\"line.product_id.display_name\"/></td>\n"
"                    <td align=\"right\"><t t-out=\"line.product_uom_qty\"/></td>\n"
"                    <td align=\"right\">\n"
"                        <t t-if=\"line.price_unit not in (False, None)\">\n"
"                            <span t-field=\"line.price_unit\" t-options=\"{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: line.currency_id}\"/>\n"
"                        </t>\n"
"                        <t t-else=\"\">—</t>\n"
"                    </td>\n"
"                    <td><t t-out=\"line.inquiry_line_note or ''\"/></td>\n"
"                </tr>\n"
"            </t>\n"
"        </tbody>\n"
"    </table>\n"
"    <t t-if=\"not is_html_empty(object.note)\">\n"
"        <p style=\"margin-top: 16px; margin-bottom: 8px;\">\n"
"            <strong>整单备注：</strong>\n"
"        </p>\n"
"        <div style=\"font-size: 13px;\" t-out=\"object.note\"/>\n"
"    </t>\n"
"</div>\n"
"            "

