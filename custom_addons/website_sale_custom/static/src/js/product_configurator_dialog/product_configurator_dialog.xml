<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="sale.ProductConfiguratorDialog" t-inherit-mode="extension">
        <button name="website_sale_product_configurator_checkout_button" position="attributes">
            <attribute name="t-if">this.customSaleEnableCheckout</attribute>
        </button>
        <button name="website_sale_product_configurator_checkout_button" position="after">
            <button
                t-if="this.customSaleEnableInquiry"
                type="button"
                name="website_sale_custom_product_configurator_inquiry_button"
                class="btn btn-outline-secondary text-nowrap w-100"
                t-on-click="() => this.onConfirmThenInquiry()"
                t-att-disabled="!isPossibleConfiguration() || !canBeSold()"
            >
                <t t-out="this.customSaleInquiryLinkLabel"/>
            </button>
        </button>
    </t>
</templates>
